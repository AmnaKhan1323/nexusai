# ============================================
# NexusAI Backend — Environment Variables
# 100% FREE — No paid APIs required!
# ============================================

# Ollama (Free, runs locally)
# Install: https://ollama.com/download
# Then run: ollama pull llama3 && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB (Free, local vector database)
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=nexusai_documents

# PostgreSQL (Free, via Docker)
DATABASE_URL=postgresql://nexusai:nexusai_secret@localhost:5432/nexusai_db

# Redis (Free, via Docker)
REDIS_URL=redis://localhost:6379/0

# App Settings
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=512
CHUNK_OVERLAP=50
