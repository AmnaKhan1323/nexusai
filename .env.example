# ============================================
# NexusAI — Root Environment Variables
# 100% FREE — No paid APIs required!
# ============================================

# PostgreSQL Database (Free, via Docker)
POSTGRES_USER=nexusai
POSTGRES_PASSWORD=nexusai_secret
POSTGRES_DB=nexusai_db

# Ollama (Free, runs locally)
# Install: https://ollama.com/download
# Then: ollama pull llama3 && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB (Free, persists to disk)
CHROMA_PERSIST_DIR=./chroma_data

# Redis (Free, via Docker)
REDIS_URL=redis://localhost:6379/0

# Backend
DATABASE_URL=postgresql://nexusai:nexusai_secret@localhost:5432/nexusai_db
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
